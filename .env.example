# Copy to .env and adjust. Loaded by app/config.py (pydantic-settings).

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ai_hub
# Fail fast (don't hang) when the DB is unreachable; bounds server selection.
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# --- Anthropic / Claude API ---
# Required when USE_MOCK_LLM=false. Leave blank to run with the mock engine.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Max tokens generated per assistant turn (bounds reply size and per-turn cost).
LLM_MAX_TOKENS=1024

# Path to the configuration-driven prompt.
PROMPT_CONFIG_PATH=config/prompt.yaml

# Set true to use the deterministic mock LLM (no network/API key needed).
USE_MOCK_LLM=false

# --- Authentication ---
# Secure by default in the app (AUTH_ENABLED=true). The local docker-compose
# turns it OFF for a zero-config demo; enable it for a realistic run.
# When enabled, every session endpoint needs a JWT bearer token and a session is
# only accessible by the principal (token "sub") that created it.
AUTH_ENABLED=true
# Required when AUTH_ENABLED=true. Use a strong random value (>=32 bytes), e.g.
# `openssl rand -hex 32`; source it from a secrets manager in production.
AUTH_SECRET=
AUTH_ALGORITHM=HS256
# Optional — verified only when set.
# AUTH_AUDIENCE=ai-hub
# AUTH_ISSUER=https://idp.example.com

# --- Cost & retention controls ---
# Only the last N transcript messages are sent to the LLM each turn (caps token
# spend on long conversations; the full history is still stored).
LLM_HISTORY_WINDOW=20
# Reject user messages longer than this many characters before they reach the LLM.
MAX_USER_MESSAGE_CHARS=4000
# Max user turns per session (each turn is an LLM call). Reached -> HTTP 409.
MAX_SESSION_TURNS=50
# Stale conversation sessions auto-expire this many seconds after their last
# update (MongoDB TTL index). Default 604800 = 7 days. Stored requests are kept.
SESSION_TTL_SECONDS=604800

# --- Observability ---
# Structured JSON logs by default; set LOG_FORMAT=text for human-readable local
# debugging. Each request carries an X-Request-ID correlation id, and request
# create/update emits a PII-free audit event on the "ai_hub.audit" logger.
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Duplicate detection (privacy-preserving, runs in-process) ---
# "embedding" = local semantic similarity (needs the embeddings extra / image).
# "lexical"   = dependency-free Jaccard overlap (offline, no ML).
# Single knob: in Docker it selects the build variant AND is baked into the
# image as the runtime default, so the image and runtime never drift.
SIMILARITY_BACKEND=embedding
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Optional similarity cut-off override. Leave unset to use each backend's tuned
# default (lexical ~0.35, embedding ~0.90, calibrated in eval/) — they are not on
# the same scale.
# DUPLICATE_SIMILARITY_THRESHOLD=0.90
